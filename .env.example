# ══════════════════════════════════════════════════════════════════════════════
# MyoGuard Protocol — Environment Variables
# Copy this file to .env and fill in the values.
# .env is gitignored. NEVER commit real credentials.
# Run `npm run preflight` to validate your local configuration.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Database (Supabase / PostgreSQL) ─────────────────────────────────────────
#
# DATABASE_URL  →  PgBouncer transaction-mode pooler (port 6543).
#   • The username MUST include your project reference for regional pooler
#     routing: postgres.[project-ref]  (NOT just "postgres")
#   • Always append ?pgbouncer=true
#
# DIRECT_URL  →  Direct connection (port 5432, bypasses PgBouncer).
#   • Used exclusively by prisma.config.ts for `prisma db push` / migrations
#   • Username is just "postgres" (no project ref needed for direct connections)
#
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ─── Clerk Authentication ──────────────────────────────────────────────────────
#
# Obtain from: https://dashboard.clerk.com → your application → API Keys
#
# IMPORTANT: Use pk_live_ / sk_live_ keys in production.
#   pk_test_ / sk_test_ keys point to a SEPARATE user database (the dev sandbox).
#   Users created under one instance do not exist in the other.
#   Switching keys in production will appear to wipe all existing users.
#
# Redirect URLs must match what is set in:
#   Clerk Dashboard → your app → User & Authentication → Email, Phone, Username
#   (or Redirects section, depending on Clerk dashboard version)
#
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_<your-clerk-publishable-key>
CLERK_SECRET_KEY=sk_test_<your-clerk-secret-key>

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in-new
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up-new
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Clerk webhook signing secret — syncs new Clerk users to your Supabase DB.
# Obtain from: Clerk Dashboard → Webhooks → add endpoint → Signing Secret
# Events to subscribe: user.created
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Resend (email delivery) ───────────────────────────────────────────────────
#
# Obtain from: https://resend.com/api-keys
# The sending domain (myoguard.health) must also be verified in Resend:
#   Resend Dashboard → Domains → Add → add the DNS records Resend provides.
# Without a valid key, welcome emails and protocol emails silently fail.
#
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Stripe (payments) ────────────────────────────────────────────────────────
#
# Obtain from: https://dashboard.stripe.com → Developers → API Keys
# Use sk_live_ / pk_live_ in production. Never commit live keys.
#
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_<your-stripe-publishable-key>
STRIPE_SECRET_KEY=sk_live_<your-stripe-secret-key>

# Stripe webhook signing secret — syncs subscription status changes back to DB.
# Obtain from: Stripe Dashboard → Webhooks → add endpoint → Signing Secret
#
# Webhook endpoint URL: https://myoguard.health/api/stripe/webhook
#
# Events to subscribe (select all five):
#   checkout.session.completed
#   customer.subscription.created
#   customer.subscription.updated
#   customer.subscription.deleted
#   invoice.payment_failed
#
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Physician subscription Price IDs ──────────────────────────────────────────
# Obtain from: Stripe Dashboard → Products → [your product] → Pricing → Price ID
#
# STRIPE_PHYSICIAN_PRICE_ID   — Solo physician recurring subscription (primary)
# STRIPE_PRACTICE_PRICE_ID    — Practice / multi-physician subscription
# STRIPE_PRICE_ID             — Legacy fallback (used if PHYSICIAN_PRICE_ID is absent)
# STRIPE_TEST_PRICE_ID        — $1 one-time product for payout pipeline verification
#                               (Create: Stripe Dashboard → Products → Add → $1.00 one-time)
#                               Remove or restrict after Mercury payout is confirmed.
#
STRIPE_PHYSICIAN_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRACTICE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_TEST_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Legacy — kept for backwards compatibility; STRIPE_PHYSICIAN_PRICE_ID takes precedence
STRIPE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Customer Portal must be configured in Stripe Dashboard before /api/stripe/portal works:
#   Stripe Dashboard → Settings → Billing → Customer portal → Activate

# ─── n8n Brain Webhook (optional) ────────────────────────────────────────────
# The n8n webhook URL that receives email-capture events for follow-up sequences
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/myoguard-email-capture
# Optional shared secret for n8n webhook authentication
N8N_WEBHOOK_SECRET=

# ─── PostHog Analytics ────────────────────────────────────────────────────────
#
# Obtain from: https://us.posthog.com → your project → Project settings → Project API key
# The project API key (phc_...) is safe to expose publicly — it is not a secret.
#
# NEXT_PUBLIC_POSTHOG_KEY  → your PostHog project API key
# NEXT_PUBLIC_POSTHOG_HOST → PostHog ingestion host (US: https://us.i.posthog.com | EU: https://eu.i.posthog.com)
#
# Analytics are DISABLED in development by default.
# Set NEXT_PUBLIC_POSTHOG_ENABLED=true to enable locally (e.g. to test event capture).
#
NEXT_PUBLIC_POSTHOG_KEY=phc_<your-posthog-project-api-key>
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# NEXT_PUBLIC_POSTHOG_ENABLED=true

# ─── Vercel Cron Secret ───────────────────────────────────────────────────────
#
# Required by both cron routes to reject unauthorised invocations.
# Vercel automatically injects this as a Bearer token in the Authorization header.
#
# To generate: openssl rand -hex 32
# Add to: Vercel Dashboard → Project → Settings → Environment Variables
#
# Cron schedules (defined in vercel.json — do NOT edit the JSON):
#   /api/cron/weekly-pulse         Monday 09:00 UTC      "0 9 * * 1"
#   /api/cron/longitudinal-summary 1st of month 09:00 UTC "0 9 1 * *"
#
CRON_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Twilio (SMS physician invites) ───────────────────────────────────────────
#
# Required for SMS patient invitations from /doctor/start page.
# Without these, email invites still work; SMS silently returns 500.
#
# Obtain from: https://console.twilio.com → Account → API keys & tokens
# TWILIO_FROM_NUMBER must be a Twilio-provisioned phone number: +1xxxxxxxxxx
#
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# ─── App ──────────────────────────────────────────────────────────────────────
#
# Used in email templates for CTA links and in health checks.
# Set to your Vercel deployment URL (or https://myoguard.health once live).
# Do NOT use localhost here in production — email links will be broken.
#
NEXT_PUBLIC_APP_URL=https://myoguard.health
