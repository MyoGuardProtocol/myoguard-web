# ─── Database (Supabase / PostgreSQL) ─────────────────────────────────────────
# Connection pooling URL (used by Prisma at runtime via PgBouncer)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Direct connection URL (used by Prisma migrations/db push — bypasses pooler)
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ─── Clerk Authentication ──────────────────────────────────────────────────────
# Obtain from: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=<your-clerk-publishable-key>
CLERK_SECRET_KEY=<your-clerk-secret-key>

# Clerk redirect URLs (must match Clerk dashboard settings)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Clerk webhook signing secret (for user.created sync → DB)
# Obtain from: Clerk Dashboard → Webhooks → Signing Secret
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Stripe Payments ──────────────────────────────────────────────────────────
# Obtain from: https://dashboard.stripe.com → Developers → API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=<your-stripe-publishable-key>
STRIPE_SECRET_KEY=<your-stripe-secret-key>

# Stripe webhook signing secret (for checkout.session.completed etc.)
# Obtain from: Stripe Dashboard → Webhooks → Signing Secret
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Price ID for the premium subscription
STRIPE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── n8n Brain Webhook ────────────────────────────────────────────────────────
# The n8n webhook URL that receives email-capture events for follow-up sequences
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/myoguard-email-capture
# Optional shared secret for n8n webhook authentication
N8N_WEBHOOK_SECRET=

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://myoguard.health
