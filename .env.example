# ══════════════════════════════════════════════════════════════════════════════
# MyoGuard Protocol — Environment Variables
# Copy this file to .env and fill in the values.
# .env is gitignored. NEVER commit real credentials.
# Run `npm run preflight` to validate your local configuration.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Database (Supabase / PostgreSQL) ─────────────────────────────────────────
#
# DATABASE_URL  →  PgBouncer transaction-mode pooler (port 6543).
#   • The username MUST include your project reference for regional pooler
#     routing: postgres.[project-ref]  (NOT just "postgres")
#   • Always append ?pgbouncer=true
#
# DIRECT_URL  →  Direct connection (port 5432, bypasses PgBouncer).
#   • Used exclusively by prisma.config.ts for `prisma db push` / migrations
#   • Username is just "postgres" (no project ref needed for direct connections)
#
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ─── Clerk Authentication ──────────────────────────────────────────────────────
#
# Obtain from: https://dashboard.clerk.com → your application → API Keys
#
# IMPORTANT: Use pk_live_ / sk_live_ keys in production.
#   pk_test_ / sk_test_ keys point to a SEPARATE user database (the dev sandbox).
#   Users created under one instance do not exist in the other.
#   Switching keys in production will appear to wipe all existing users.
#
# Redirect URLs must match what is set in:
#   Clerk Dashboard → your app → User & Authentication → Email, Phone, Username
#   (or Redirects section, depending on Clerk dashboard version)
#
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_<your-clerk-publishable-key>
CLERK_SECRET_KEY=sk_test_<your-clerk-secret-key>

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in-new
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up-new
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Clerk webhook signing secret — syncs new Clerk users to your Supabase DB.
# Obtain from: Clerk Dashboard → Webhooks → add endpoint → Signing Secret
# Events to subscribe: user.created
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Resend (email delivery) ───────────────────────────────────────────────────
#
# Obtain from: https://resend.com/api-keys
# The sending domain (myoguard.health) must also be verified in Resend:
#   Resend Dashboard → Domains → Add → add the DNS records Resend provides.
# Without a valid key, welcome emails and protocol emails silently fail.
#
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Stripe (payments) ────────────────────────────────────────────────────────
#
# Obtain from: https://dashboard.stripe.com → Developers → API Keys
# Use sk_test_ / pk_test_ in dev; sk_live_ / pk_live_ in production.
#
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_<your-stripe-publishable-key>
STRIPE_SECRET_KEY=sk_test_<your-stripe-secret-key>

# Stripe webhook signing secret — syncs subscription status changes back to DB.
# Obtain from: Stripe Dashboard → Webhooks → add endpoint → Signing Secret
# Events to subscribe: checkout.session.completed, customer.subscription.*
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Price ID for the premium subscription plan.
# Obtain from: Stripe Dashboard → Products → your product → Pricing → Price ID
STRIPE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── n8n Brain Webhook (optional) ────────────────────────────────────────────
# The n8n webhook URL that receives email-capture events for follow-up sequences
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/myoguard-email-capture
# Optional shared secret for n8n webhook authentication
N8N_WEBHOOK_SECRET=

# ─── App ──────────────────────────────────────────────────────────────────────
#
# Used in email templates for CTA links and in health checks.
# Set to your Vercel deployment URL (or https://myoguard.health once live).
# Do NOT use localhost here in production — email links will be broken.
#
NEXT_PUBLIC_APP_URL=https://myoguard.health
