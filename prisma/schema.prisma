generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String               @id @default(cuid())
  clerkId             String               @unique
  email               String               @unique
  fullName            String
  role                Role                 @default(PATIENT)
  subscriptionStatus  SubscriptionStatus   @default(FREE)
  stripeCustomerId    String?
  stripeSubId         String?
  referralSlug        String?
  referralCode        String?              @unique
  referredById        String?
  physicianId         String?
  isVerified          Boolean              @default(false)
  npiNumber           String?
  researchConsent     Boolean              @default(false)
  consentDate         DateTime?
  consentVersion      String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  assessments         Assessment[]
  muscleScores        MuscleScore[]
  notifications       Notification[]
  physicianOnboarding PhysicianOnboarding?
  physicianReviews    PhysicianReview[]
  progressLogs        ProgressLog[]
  protocolPlans       ProtocolPlan[]
  shareCards          ShareCard[]
  referredBy          User?                @relation("Referrals", fields: [referredById], references: [id])
  referrals           User[]               @relation("Referrals")
  profile             UserProfile?
  weeklyCheckins      WeeklyCheckin[]
}

model PhysicianProfile {
  id            String   @id @default(cuid())
  slug          String   @unique
  displayName   String
  clinicName    String?
  specialty     String?
  startSheetUrl String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  /// Human-readable code shared with patients: e.g. DR-OKPALA-472
  /// Patients enter this during onboarding to link their account.
  referralCode  String?  @unique
}

model UserProfile {
  id              String        @id @default(cuid())
  userId          String        @unique
  age             Int
  sex             Sex
  heightCm        Float
  weightKg        Float
  goalWeightKg    Float?
  activityLevel   ActivityLevel
  glp1Medication  String
  glp1DoseMg      Float
  glp1Stage       Glp1Stage
  treatmentStart  DateTime
  baselineProtein Float?
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Assessment {
  id              String           @id @default(cuid())
  userId          String
  assessmentDate  DateTime         @default(now())
  weightKg        Float
  proteinGrams    Float
  exerciseDaysWk  Int
  hydrationLitres Float
  symptoms        String[]
  fatigue         Int
  nausea          Int
  muscleWeakness  Int
  score           Float
  riskBand        RiskBand
  createdAt       DateTime         @default(now())
  /// Hours of sleep reported at assessment time
  sleepHours      Float?
  /// 1 (Very poor) – 5 (Excellent) — self-reported sleep quality
  sleepQuality    Int?
  /// Derived recovery status: 'optimal' | 'impaired' | 'critical'
  recoveryStatus  String?
  /// Hand-grip dynamometer reading in kg — used for grip-velocity triage
  gripStrengthKg  Float?
  /// GLP-1 treatment stage captured at assessment time: INITIATION | DOSE_ESCALATION | MAINTENANCE | DISCONTINUATION
  glp1Stage       String?
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  muscleScore     MuscleScore?
  physicianReview PhysicianReview?
  protocolPlan    ProtocolPlan?
}

model MuscleScore {
  id             String     @id @default(cuid())
  userId         String
  assessmentId   String     @unique
  score                  Float
  riskBand               RiskBand
  leanLossEstPct         Float
  proteinTargetG         Float
  explanation            String
  generatedAt            DateTime   @default(now())
  /// Lower-bound protein target (activity-adjusted clinical floor)
  proteinStandardG       Float?
  /// Temporary step-down protein target for moderate/severe GI symptoms
  proteinStepTargetG     Int?
  /// Explains the floor/step distinction and when full floor resumes
  stepRationale          String?
  /// GI severity classification: none | mild | moderate | severe
  giSeverity             String?
  /// Estimated lean mass loss velocity derived from leanLossEstPct
  leanVelocityPct        Float?
  /// Lean velocity flag: insufficient_data | stable | concerning | critical_review
  leanVelocityFlag       String?
  /// GLP-1 stage multiplier applied to score (1.0 = no stage pressure)
  stageMultiplierApplied Float?
  /// Floor-based protein adherence at assessment time: (most recent WeeklyCheckin.avgProteinG / proteinStandardG) × 100
  /// Uses Clinical Protein Floor as denominator — not the aggressive target — for accurate Level 3 tripwire evaluation.
  recentProteinAdherencePct Float?
  assessment     Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProtocolPlan {
  id               String     @id @default(cuid())
  userId           String
  assessmentId     String     @unique
  proteinTargetG   Float
  proteinSources   String[]
  supplementation  String[]
  trainingPlan     String
  hydrationTarget  Float
  electrolyteNotes String
  giGuidance       String
  createdAt        DateTime   @default(now())
  assessment       Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProgressLog {
  id              String   @id @default(cuid())
  userId          String
  logDate         DateTime @default(now())
  weightKg        Float
  proteinGrams    Float
  workoutsCount   Int
  hydrationLitres Float
  energyLevel     Int
  nauseaLevel     Int
  notes           String?
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WeeklyCheckin {
  id                String    @id @default(cuid())
  userId            String
  weekStart         DateTime
  weekEnd           DateTime
  avgWeightKg       Float?
  avgProteinG       Float?
  totalWorkouts     Int?
  avgHydration      Float?
  scoreDelta        Float?
  proteinAdherence  Float?
  exerciseAdherence Float?
  highlights        String[]
  recommendations   String[]
  completedAt       DateTime?
  createdAt         DateTime  @default(now())
  /// 1 (Very low) – 5 (Excellent) — self-reported from the weekly check-in form
  energyLevel       Int?
  /// 1 (None) – 5 (Severe) — self-reported from the weekly check-in form
  nauseaLevel       Int?
  /// Hours of sleep reported for the check-in week
  sleepHours        Float?
  /// 1 (Very poor) – 5 (Excellent) — self-reported sleep quality
  sleepQuality      Int?
  /// Derived recovery status: 'optimal' | 'impaired' | 'critical'
  recoveryStatus    String?
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ShareCard {
  id         String   @id @default(cuid())
  userId     String
  score      Float
  riskBand   RiskBand
  imageUrl   String?
  shareToken String   @unique @default(cuid())
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReferralInvite {
  id           String    @id @default(cuid())
  token        String    @unique @default(cuid())
  createdById  String
  redeemedById String?   @unique
  expiresAt    DateTime
  redeemedAt   DateTime?
  createdAt    DateTime  @default(now())
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  subject   String
  body      String
  sentAt    DateTime?
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PhysicianReview {
  id                String     @id @default(cuid())
  assessmentId      String     @unique
  userId            String
  overallImpression String?
  followUpDays      Int?
  note              String?
  reviewedAt        DateTime
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  assessment        Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Tracks cumulative physician review time per patient per billing month.
// Used to determine CPT 99470 eligibility (≥ 10 minutes of documented review).
model PhysicianReviewSession {
  id                String   @id @default(cuid())
  physicianId       String
  patientId         String
  billingMonth      String   // "YYYY-MM"
  cumulativeSeconds Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([physicianId, patientId, billingMonth])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  targetType String
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
}

model PhysicianOnboarding {
  id            String   @id @default(cuid())
  userId        String   @unique
  country       String
  specialty     String?
  licenseNumber String?
  submittedAt   DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PhysicianApplication {
  id               String    @id @default(cuid())
  name             String
  email            String    @unique
  country          String
  specialty        String
  license          String?
  npi              String?
  status           String    @default("PENDING")
  submittedAt      DateTime  @default(now())
  reviewedAt       DateTime?
  reviewNote       String?
  adminToken       String?   @unique
  adminTokenExpiry DateTime?
  clerkUserId      String?
}

model StartSheetProtocol {
  id                  String   @id @default(cuid())
  physicianClerkId    String
  patientName         String
  patientEmail        String
  weightKg            Float
  age                 Int
  glp1Agent           String
  riskLevel           String
  proteinTarget       Float
  hydrationTarget     Float
  resistanceFrequency String
  supplements         String[]
  ermEnabled          Boolean  @default(false)
  physicianNotes      String?  @default("")
  createdAt           DateTime @default(now())
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  eventType String
  metadata  Json?
  createdAt DateTime @default(now())
}

model PreloadedAssessment {
  id          String   @id @default(cuid())
  physicianId String
  patientName  String?
  patientEmail String?
  payload     Json
  used        Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
}

enum Role {
  PATIENT
  PHYSICIAN
  ADMIN
  PHYSICIAN_PENDING
}

enum Sex {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum ActivityLevel {
  SEDENTARY
  LIGHTLY_ACTIVE
  MODERATELY_ACTIVE
  VERY_ACTIVE
}

enum Glp1Stage {
  INITIATION
  DOSE_ESCALATION
  MAINTENANCE
  DISCONTINUING
}

enum RiskBand {
  LOW
  MODERATE
  HIGH
  CRITICAL
}

enum SubscriptionStatus {
  FREE
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum NotificationType {
  WEEKLY_REMINDER
  REPORT_READY
  PAYMENT_CONFIRMED
  WELCOME
}

// ─── Observational Study Infrastructure ────────────────────────────────────
// Phase: Research-Ready Architecture
// All models below are additive — no existing tables or enums are modified.
//
// Relation strategy: references to existing models (User, Assessment) use plain
// scalar String fields with no @relation directive. This preserves zero-touch on
// existing clinical models and passes prisma validate without back-relations.
// Application code must verify existence of referenced IDs before writes.
//
// Terminology rules (non-negotiable, CLAUDE.md):
//   "Sarcopenia Risk Index (SRI)" — never "calculator", never bare "score"
//   "generate" / "generated" — never "calculate" / "calculated"
//   sriScore — internal research field; never exposed in UI; never sent to PostHog
//   Export column label: "sri_value_internal" in CSV / statistical output files
// ───────────────────────────────────────────────────────────────────────────

/// Lifecycle state of a named observational study.
enum StudyStatus {
  DRAFT
  ACTIVE
  CLOSED
  ARCHIVED
}

/// Lifecycle state of a patient's enrollment in a specific study.
enum EnrollmentStatus {
  ACTIVE
  WITHDRAWN
  COMPLETED
}

/// Structured event types for the research audit trail.
/// AuditLog (existing) handles system/compliance events.
/// StudyEventLog handles research workflow milestones.
enum StudyEventType {
  ENROLLMENT
  REASSESSMENT
  PROTOCOL_MODIFICATION
  PHYSICIAN_REVIEW
  ADHERENCE_CHECKPOINT
  WITHDRAWAL
}

/// A named physician-led observational study.
/// Anchors cohort grouping, enrollment management, and research event logging.
model Study {
  id          String      @id @default(cuid())
  title       String
  /// URL-safe unique identifier — e.g., "glp1-sarcopenia-2026".
  slug        String      @unique
  description String?
  status      StudyStatus @default(DRAFT)

  /// User.id of the creating physician.
  /// Plain scalar — no @relation (zero-touch on existing User model).
  /// Always User.id — never clerkId, referralSlug, referralCode, or physicianClerkId.
  /// Application must verify: (a) User exists, (b) User.role = PHYSICIAN.
  createdById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollments StudyEnrollment[]
  eventLog    StudyEventLog[]

  @@index([createdById])
  @@index([status])
}

/// Links a patient to a named observational study under a specific physician.
/// researchParticipantId is the sole export-safe patient identifier.
/// patientId is internal — excluded from all research exports and publication.
model StudyEnrollment {
  id      String @id @default(cuid())
  studyId String
  study   Study  @relation(fields: [studyId], references: [id])

  /// User.id of the enrolled patient.
  /// Plain scalar — no @relation (zero-touch on existing User model).
  /// NEVER included in research exports or publication datasets.
  /// Application must verify User exists and User.researchConsent = true.
  patientId String

  /// User.id of the responsible physician.
  /// Plain scalar — no @relation (zero-touch on existing User model).
  /// Always User.id — never clerkId, referralSlug, referralCode, or physicianClerkId.
  /// Application must verify User exists and User.role = PHYSICIAN.
  physicianId String

  enrolledAt     DateTime         @default(now())
  /// Stamped when the patient's StudyConsent record is first created.
  consentedAt    DateTime?
  status         EnrollmentStatus @default(ACTIVE)
  /// Set when status transitions to WITHDRAWN. Previously collected snapshots are preserved.
  withdrawalDate DateTime?

  /// Optional free-form cohort segmentation label within a study.
  /// Examples: "GLP-1 Initiation", "Dose Escalation Q3-2026"
  cohortLabel String?

  /// UUID v4 — the sole patient identifier in all research exports and publications.
  /// Generated at enrollment; never updated. Non-sequential; non-reversible to patientId.
  /// Compatible with R, SPSS, Python, and CSV statistical workflows.
  researchParticipantId String @unique @default(uuid())

  consents  StudyConsent[]
  snapshots AssessmentSnapshot[]
  eventLog  StudyEventLog[]

  /// Prevents double-enrollment of the same patient in the same study.
  @@unique([studyId, patientId])
  @@index([patientId])
  @@index([physicianId])
  @@index([studyId, status])
}

/// Records a patient's data-use consent for a specific study enrollment.
/// Multiple records per enrollment are allowed — operative consent is the latest signedAt.
/// Does not replace User.researchConsent (general data-use prerequisite).
///
/// Required UI positioning: "MyoGuard Protocol is a physician-led Clinical Decision
/// Support (CDS) platform. Participation in observational data collection is voluntary
/// and does not affect your clinical care."
model StudyConsent {
  id           String          @id @default(cuid())
  enrollmentId String
  enrollment   StudyEnrollment @relation(fields: [enrollmentId], references: [id])

  /// Semantic version of the consent text at signing time — e.g., "1.0", "1.1".
  /// Application gate compares against minimum required version.
  /// Null User.consentVersion is treated as "0.0" in application gate logic only.
  consentVersion String

  /// Full verbatim text of the consent document at signing time.
  /// Immutable after creation — legal record of what the patient agreed to.
  consentTextSnapshot String

  /// Optional IP address for consent provenance. Excluded from all research exports.
  ipAddress String?

  signedAt DateTime @default(now())

  @@index([enrollmentId])
}

/// Immutable research-safe snapshot of a clinical assessment at point-in-time capture.
/// Created non-blocking (fire-and-forget) after Assessment creation when the patient
/// has an ACTIVE StudyEnrollment with a valid operative StudyConsent.
/// Assessment creation always succeeds even if snapshot creation fails.
///
/// Immutability contract: records are NEVER updated after creation.
/// Corrections require a new Assessment (new snapshot) with a PROTOCOL_MODIFICATION
/// entry in StudyEventLog documenting the reason.
///
/// sriScore: internal research value only.
///   1. Never surfaced in patient-facing or physician-facing UI.
///   2. Never transmitted to PostHog or any external analytics provider.
///   3. Export column header must be "sri_value_internal".
model AssessmentSnapshot {
  id String @id @default(cuid())

  /// Assessment.id of the source clinical record.
  /// Plain scalar — no @relation (zero-touch on existing Assessment model).
  /// Application must verify Assessment exists before snapshot creation.
  assessmentId String

  /// Required: every snapshot belongs to an active StudyEnrollment.
  /// Non-nullable — no orphan/context-free snapshots in this phase.
  enrollmentId String
  enrollment   StudyEnrollment @relation(fields: [enrollmentId], references: [id])

  /// SRI risk band at snapshot time.
  sriBand RiskBand

  /// SRI numeric output (0–100) at snapshot time. Internal research value only.
  /// Used for regression, trajectory, cohort means, and SD in statistical analysis.
  /// See immutability contract above for exposure rules.
  sriScore Float

  /// Prescribed protein target (g/day) from MuscleScore at snapshot time.
  proteinTargetG Float

  /// Prescribed hydration target (litres/day) from ProtocolPlan at snapshot time.
  hydrationTargetL Float

  /// Patient activity status at assessment time. Stored as String to preserve
  /// historical value if ActivityLevel enum changes in future.
  activityStatus String

  /// Symptom array at snapshot time. Structured codes only — no free-text PHI.
  symptoms Json

  /// GI tolerance from MuscleScore.giSeverity: none | mild | moderate | severe
  giTolerance String?

  /// Self-reported sleep quality (1 = Very poor, 5 = Excellent).
  sleepQuality Int?

  /// Hand-grip dynamometer reading (kg). Sparse — not required at assessment time.
  gripStrengthKg Float?

  /// GLP-1 treatment stage at assessment time. Stored as String to preserve
  /// historical value if Glp1Stage enum changes in future.
  glp1Stage String?

  /// Patient weight (kg) at assessment time.
  /// Quasi-identifier: export layer must bucket (e.g., 5 kg bands) in publication
  /// datasets when combined with age and sex to reduce re-identification risk.
  weightKg Float

  /// Timestamp of snapshot creation. May differ from Assessment.assessmentDate
  /// if snapshot creation is delayed in a fire-and-forget retry scenario.
  snapshotDate DateTime @default(now())

  /// One snapshot per (assessment, enrollment) pair. Both fields non-nullable:
  /// constraint is unambiguous with no NULL edge cases.
  @@unique([assessmentId, enrollmentId])
  @@index([enrollmentId])
  @@index([assessmentId])
}

/// Structured research audit trail for observational study milestones.
/// Distinct from AuditLog (system/compliance events).
/// Append-only by convention: no updates, no deletes.
///
/// eventData Json key naming (non-negotiable):
///   "sri_band" not "score" | "sri_value_internal" not "sriScore" in event payloads
///   "generated" not "calculated" | no PHI values (no names, emails, direct IDs)
model StudyEventLog {
  id      String @id @default(cuid())
  studyId String
  study   Study  @relation(fields: [studyId], references: [id])

  /// Nullable: supports study-level events (e.g., study status change) without
  /// a specific enrollment context.
  enrollmentId String?
  enrollment   StudyEnrollment? @relation(fields: [enrollmentId], references: [id])

  /// Internal patient identifier for physician-facing audit queries.
  /// Plain scalar — no @relation (zero-touch on existing User model).
  /// NEVER included in research exports or publication datasets.
  patientId String?

  eventType StudyEventType

  /// Structured event payload — no PHI. Per-eventType key conventions:
  ///   ENROLLMENT            → { cohort_label, consent_version }
  ///   REASSESSMENT          → { sri_band, sri_value_internal, interval_days }
  ///   PROTOCOL_MODIFICATION → { field_modified, reason }
  ///   PHYSICIAN_REVIEW      → { overall_impression, follow_up_days }
  ///   ADHERENCE_CHECKPOINT  → { protein_adherence, exercise_adherence, recovery_status }
  ///   WITHDRAWAL            → { reason, initiated_by }
  eventData Json?

  recordedAt DateTime @default(now())

  /// User.id of the recording actor (physician or system).
  /// Plain scalar — no @relation (zero-touch on existing User model).
  /// Always User.id — never clerkId.
  recordedBy String

  @@index([studyId])
  @@index([enrollmentId])
  @@index([studyId, eventType])
  @@index([recordedAt])
}
